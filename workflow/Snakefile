##### Modules #####

rule prepare_reference:
    """
    Prepare reference genome and annotation
    from local files or NCBI.
    """
    output:
        fasta="resources/genome.fasta",
        gff="resources/genes.gff3"
    params:
        source=config["reference"]["source"],
        accession=config["reference"].get("accession", ""),
        local_fasta=config["reference"].get("fasta", ""),
        local_gff=config["reference"].get("gff", "")
    conda:
        "envs/ncbi-datasets.yaml"
    log:
        "logs/reference.log"
    shell:
        """
        mkdir -p resources
        mkdir -p tmp/reference

        # Always clean up temp folder afterwards
        trap 'rm -rf tmp/reference' EXIT

        if [ "{params.source}" = "local" ]; then

            ln -sf $(realpath {params.local_fasta}) {output.fasta}
            ln -sf $(realpath {params.local_gff}) {output.gff}

        elif [ "{params.source}" = "ncbi" ]; then

            datasets download genome accession {params.accession} \
                --include genome,gff3 \
                --filename tmp/reference/reference.zip \
                > {log} 2>&1

            unzip -o tmp/reference/reference.zip \
                -d tmp/reference >> {log} 2>&1

            GENOME=$(find tmp/reference -name "*genomic.fna" | head -n1)
            GFF=$(find tmp/reference -name "*.gff*" | head -n1)

            if [ -z "$GENOME" ] || [ -z "$GFF" ]; then
                echo "Genome or GFF not found in downloaded dataset" >&2
                exit 1
            fi

            cp "$GENOME" {output.fasta}
            cp "$GFF" {output.gff}

        else
            echo "Invalid reference source: {params.source}" >&2
            exit 1
        fi
        """

# And look in to this: https://snakemake-wrappers.readthedocs.io/en/stable/wrappers/bio/sra-tools/fasterq-dump.html 
# Update the rest and make more in wrappers.

