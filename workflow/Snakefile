        "results/filtered/all.snvs.selected.vcf.gz",
        "results/msa/snvs.fasta",
        "results/phylogeny/fasttree-snvs.nwk",


##### Modules #####


rule get_genome:
    """
    Download data from NCBI and place it to correct location
    """
    output:
        fasta="resources/genome.fasta",
        zip=temp("resources/datasets/ref.zip"),
        dir=temp(directory("resources/datasets/ref")),
    log:
        "logs/datasets/ref.log",
    # wildcard_constraints:
    #     sample=ACCESSION_SAMPLES
    conda:
        "envs/ncbi-datasets.yaml"
    params:
        accession=ref_id,
    shell:
        """
        datasets download genome accession {params.accession} --include genome --filename {output.zip}
        unzip {output.dir}.zip -d {output.dir}
        mv {output.dir}/ncbi_dataset/data/{params.accession}/{params.accession}*_genomic.fna {output.fasta}
        """


rule get_fastq_pe_gz:
    output:
        # the wildcard name must be accession, pointing to an SRA number
        "resources/reads/{accession}_1.fastq.gz",
        "resources/reads/{accession}_2.fastq.gz",
    log:
        "logs/fasterq-dump/{accession}.gz.log",
    threads: 6  # defaults to 6
    params:
        extra="--skip-technical",
    wrapper:
        "v9.8.0/bio/sra-tools/fasterq-dump"


# include: "rules/ref.smk"
# skipped variants (vep)


checkpoint genome_faidx:
    input:
        "resources/genome.fasta",
    output:
        "resources/genome.fasta.fai",
    log:
        "logs/genome-faidx.log",
    cache: True
    params:
        extra="",
    wrapper:
        "v8.1.1/bio/samtools/faidx"


rule intervals_from_fai:
    input:
        "resources/genome.fasta.fai",
    output:
        "resources/intervals.list",
    log:
        "logs/intervals-from-fai.log",
    shell:
        "cut -f1 {input} > {output} 2> {log}"


rule genome_dict:
    input:
        "resources/genome.fasta",
    output:
        "resources/genome.dict",
    log:
        "logs/samtools/create_dict.log",
    cache: True
    conda:
        "envs/samtools.yaml"
    shell:
        "samtools dict {input} > {output} 2> {log} "


rule bwa_index:
    input:
        "resources/genome.fasta",
    output:
        idx=multiext("resources/genome.fasta", ".amb", ".ann", ".bwt", ".pac", ".sa"),
    log:
        "logs/bwa_index.log",
    wrapper:
        "v5.10.0/bio/bwa/index"


include: "rules/mapping.smk"


# include: "rules/calling.smk"

if "restrict-regions" in config["processing"]:

    rule compose_regions:
        input:
            config["processing"]["restrict-regions"],
        output:
            "results/called/{contig}.regions.bed",
        conda:
            "envs/bedops.yaml"
        shell:
            "bedextract {wildcards.contig} {input} > {output}"


rule call_variants:
    input:
        bam=get_sample_bams_dedup,
        bai=get_sample_bai_dedup,
        ref="resources/genome.fasta",
        fai="resources/genome.fasta.fai",
        idx="resources/genome.dict",
    output:
        gvcf="results/called/{sample}.g.vcf.gz",
    log:
        "logs/gatk/haplotypecaller/{sample}.log",
    threads: 4
    resources:
        mem_mb=1024,
    params:  # Some need to be moved to config
        extra="-G StandardAnnotation -G AS_StandardAnnotation -G StandardHCAnnotation "
        + config["params"]["gatk"]["HaplotypeCaller"]
        + " -sample-name {sample}",
    wrapper:
        "v7.6.0/bio/gatk/haplotypecaller"


rule genomics_db_import:
    input:
        gvcfs=expand("results/called/{sample}.g.vcf.gz", sample=samples.index),
        interval_list="resources/intervals.list",
    output:
        db=directory("results/genomicsdb"),
    log:
        "logs/gatk/genomicsdbimport.log",
    threads: 2
    resources:
        mem_mb=lambda wildcards, input: max([input.size_mb * 1.6, 200]),
    params:
        intervals=lambda w, input: input.interval_list,
        db_action="create",  # optional
        extra="",  # optional
        java_opts="",  # optional
    wrapper:
        "v7.6.0/bio/gatk/genomicsdbimport"


