# Genotype the GVCFs
#####################################


rule genotype_gvcfs:
    input:
        genomicsdb="results/genomicsdb",
        # gvcf="calls/all.g.vcf",  # combined gvcf over multiple samples
        # N.B. gvcf or genomicsdb must be specified
        # in the latter case, this is a GenomicsDB data store
        ref="resources/genome.fasta",
    output:
        vcf="results/genotyped/all.vcf.gz",
    log:
        "logs/gatk/genotypegvcfs.log",
    resources:
        mem_mb=1024,
    params:
        extra="",  # optional
        java_opts="",  # optional
    wrapper:
        "v7.6.0/bio/gatk/genotypegvcfs"


# include: "rules/filtering.smk"


rule select_calls:
    input:
        ref="resources/genome.fasta",
        vcf="results/genotyped/all.vcf.gz",
    output:
        vcf=temp("results/filtered/all.{vartype}.raw.vcf.gz"),
    log:
        "logs/gatk/selectvariants/{vartype}.log",
    params:
        extra=get_vartype_arg,
    wrapper:
        "v7.6.0/bio/gatk/selectvariants"


rule filter_calls:
    input:
        ref="resources/genome.fasta",
        vcf="results/filtered/all.{vartype}.raw.vcf.gz",
    output:
        vcf=temp("results/filtered/all.{vartype}.hardfiltered.vcf.gz"),
    params:
        filters=get_filter,
        extra="",  # optional arguments; could add --genotype-filter-expression 'GQ < 50.0' --genotype-filter-name "genotype_filters" --set-filtered-genotype-to-no-call
    log:
        "logs/gatk/variantfiltration/{vartype}.log",
    wrapper:
        "v7.6.0/bio/gatk/variantfiltration"


rule select_pass_calls:
    input:
        vcf="results/filtered/all.{vartype}.hardfiltered.vcf.gz",
        ref="resources/genome.fasta",
    output:
        vcf="results/filtered/all.{vartype}.selected.vcf.gz",
    log:
        "logs/gatk/select-pass/{vartype}.log",
    resources:
        mem_mb=1024,
    params:
        extra="--exclude-filtered",  # optional filter arguments, see GATK docs
        java_opts="",  # optional
    wrapper:
        "v7.6.0/bio/gatk/selectvariants"


